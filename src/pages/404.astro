---
import Base from '../layouts/Base.astro';
import { t } from '../i18n';
import { localizedPath } from '../i18n/routing';

const locale = 'en';
---

<Base
  locale={locale}
  slug=""
  title={t(locale, 'notFound.title')}
  description={t(locale, 'notFound.body')}
>
  <section class="notfound container-page">
    <p class="eyebrow">404</p>
    <h1>{t(locale, 'notFound.heading')}</h1>
    <p class="nf-body">{t(locale, 'notFound.body')}</p>
    <div class="nf-ctas">
      <a class="btn btn-primary" href={localizedPath(locale, '')}>{t(locale, 'notFound.home')}</a>
      <a class="btn btn-secondary" href={localizedPath(locale, 'how-it-works')}>{t(locale, 'notFound.howItWorks')}</a>
      <a class="btn btn-ghost" href={localizedPath(locale, 'lost-cart-revenue-calculator')}>{t(locale, 'notFound.calculator')}</a>
    </div>
  </section>
</Base>

<style>
  .notfound {
    max-width: 44rem;
    padding-block: clamp(3rem, 10vw, 7rem);
    text-align: center;
  }
  .notfound h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0.75rem 0 1rem;
  }
  .nf-body {
    color: var(--color-ink-soft);
    font-size: 1.05rem;
    max-width: 34rem;
    margin-inline: auto;
  }
  .nf-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.75rem;
  }
</style>
