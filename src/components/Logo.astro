---
/**
 * Brand mark: a cart glyph wrapped by a "sync" arc with one accent dot —
 * "the cart that follows you." Monochrome ink + single marigold accent.
 */
interface Props {
  variant?: 'full' | 'mark';
  class?: string;
  invert?: boolean; // for the dark footer band
}
const { variant = 'full', class: cls = '', invert = false } = Astro.props;
const ink = invert ? '#F7F4EE' : '#1C1815';
const accent = '#D8541E';
---

<span class={`logo ${cls}`} data-invert={invert}>
  <svg
    class="logo-mark"
    width="30"
    height="30"
    viewBox="0 0 32 32"
    fill="none"
    aria-hidden="true"
    xmlns="http://www.w3.org/2000/svg"
  >
    {/* sync arc */}
    <path
      d="M25.5 9.5a11 11 0 1 0 2.2 8.2"
      stroke={accent}
      stroke-width="2.4"
      stroke-linecap="round"
    />
    <path d="M25.8 4.6v5.2h-5.2" stroke={accent} stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
    {/* cart */}
    <path
      d="M9 11h11.4l-1.3 6.4a1.5 1.5 0 0 1-1.47 1.2h-6.06a1.5 1.5 0 0 1-1.47-1.18L8 8.4H6"
      stroke={ink}
      stroke-width="2.1"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    <circle cx="11.4" cy="22.4" r="1.5" fill={ink} />
    <circle cx="17.2" cy="22.4" r="1.5" fill={ink} />
  </svg>
  {
    variant === 'full' && (
      <span class="logo-word" style={`color:${ink}`}>
        Persistent<span class="logo-word-2"> Cart</span>
      </span>
    )
  }
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .logo-mark {
    flex: none;
  }
  .logo-word {
    font-family: var(--font-display);
    font-weight: 540;
    font-size: 1.18rem;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }
  .logo-word-2 {
    font-weight: 400;
  }
</style>
