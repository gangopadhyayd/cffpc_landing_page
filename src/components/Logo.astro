---
/**
 * Brand mark: a phone (front) and laptop (back) sharing ONE marigold cart
 * drawn across the seam — "the same cart on both devices." Ink devices +
 * single accent cart; paper halo separates the cart from the frames.
 */
interface Props {
  variant?: 'full' | 'mark';
  class?: string;
  invert?: boolean; // for the dark footer band
}
const { variant = 'full', class: cls = '', invert = false } = Astro.props;
const ink = invert ? '#F7F4EE' : '#1C1815';
const paper = invert ? '#14233A' : '#F7F4EE';
const accent = '#D8541E';
---

<span class={`logo ${cls}`} data-invert={invert}>
  <svg
    class="logo-mark"
    width="30"
    height="30"
    viewBox="0 0 32 32"
    fill="none"
    aria-hidden="true"
    xmlns="http://www.w3.org/2000/svg"
  >
    {/* laptop: screen + base */}
    <rect x="10.5" y="6.5" width="17" height="12" rx="1.8" stroke={ink} stroke-width="2" />
    <rect x="8" y="20.2" width="22" height="2.6" rx="1.3" fill={ink} />
    {/* phone: portrait, paper fill occludes the laptop behind it */}
    <rect x="2.6" y="9.5" width="9.6" height="16.5" rx="2.6" fill={paper} stroke={ink} stroke-width="2" />
    <line x1="6" y1="23.2" x2="8.8" y2="23.2" stroke={ink} stroke-width="1.6" stroke-linecap="round" />
    {/* one cart spanning the seam (paper halo underneath, then marigold) */}
    <path
      d="M11 12.2h9.8l-1.15 5.2a1.3 1.3 0 0 1-1.27 1.02h-4.9a1.3 1.3 0 0 1-1.27-1.02L10.2 10h-1.7"
      stroke={paper}
      stroke-width="4.6"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    <path
      d="M11 12.2h9.8l-1.15 5.2a1.3 1.3 0 0 1-1.27 1.02h-4.9a1.3 1.3 0 0 1-1.27-1.02L10.2 10h-1.7"
      stroke={accent}
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    <circle cx="13.1" cy="21.4" r="1.35" fill={accent} />
    <circle cx="18.2" cy="21.4" r="1.35" fill={accent} />
  </svg>
  {
    variant === 'full' && (
      <span class="logo-word" style={`color:${ink}`}>
        Persistent<span class="logo-word-2"> Cart</span>
      </span>
    )
  }
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .logo-mark {
    flex: none;
  }
  .logo-word {
    font-family: var(--font-display);
    font-weight: 540;
    font-size: 1.18rem;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }
  .logo-word-2 {
    font-weight: 400;
  }
</style>
