---
/**
 * "Built for Shopify" certification badge.
 * - variant "official": the badge lockup from Shopify's Built-for-Shopify media
 *   kit 2025 (owner-provided, design-assets/built-for-shopify-media-kit-2025;
 *   copies served from /badges/). Use where there's room for the full pill.
 * - variant "inline" (default): compact diamond glyph + text label for slim
 *   contexts (announce bar). Glyph matches the official gem.
 * The footer's global disclaimer covers trademark attribution.
 */
interface Props {
  label: string;
  size?: number; // inline: glyph height px · official: pill height px
  variant?: 'inline' | 'official';
  /** official variant only: light pill (for light bg) or dark pill */
  tone?: 'light' | 'dark';
  class?: string;
}
const { label, size = 14, variant = 'inline', tone = 'light', class: cls = '' } = Astro.props;
const officialSrc = `/badges/badge-built-for-shopify-${tone}.svg`;
// Official lockup is 166×44 — keep its aspect ratio at the requested height.
const officialH = variant === 'official' ? (size === 14 ? 32 : size) : 0;
const officialW = Math.round(officialH * (166 / 44));
---

{variant === 'official' ? (
  <img class={`bfs-official ${cls}`} src={officialSrc} width={officialW} height={officialH} alt={label} loading="lazy" />
) : (

<span class={`bfs-badge ${cls}`}>
  <svg width={size * (16 / 14)} height={size} viewBox="0 0 16 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="m13 0-1 5-4 9 8-9.5L13 0ZM3 0l1 5 4 9-8-9.5L3 0Z" fill="#1495CC"></path>
    <path d="m3 0 1 5 4 9 4-9 1-5H3Z" fill="#58B7DF"></path>
    <path d="M8 14 4 5l-4-.5L8 14ZM8 14l4-9 4-.5L8 14Z" fill="#035F86"></path>
    <path d="M8 5.5 4 5l4 9 4-9-4 .5Z" fill="#1495CC"></path>
    <path d="m4 5 4-5 4 5-4.001.5L4 5Z" fill="#A9DEF4"></path>
    <path d="M4 5 3 0h5L4 5ZM12 5l1-5H8l4 5Z" fill="#58B7DF"></path>
    <path d="M4 5 3 0 0 4.5 4 5ZM12 5l1-5 3 4.5-4 .5Z" fill="#1495CC"></path>
  </svg>
  <span class="bfs-label">{label}</span>
</span>
)}

<style>
  .bfs-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    white-space: nowrap;
  }
  .bfs-badge svg {
    flex: none;
  }
  .bfs-label {
    font-weight: 600;
  }
  .bfs-official {
    display: inline-block;
    border-radius: 4px;
  }
</style>
