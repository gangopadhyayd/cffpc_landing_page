---
/**
 * Official "Built for Shopify" badge — Shopify's diamond glyph (as rendered on
 * our own App Store listing, which holds the certification) + label. Used as a
 * factual certification mark next to trust copy; the footer's global
 * disclaimer covers the trademark attribution.
 */
interface Props {
  label: string;
  size?: number; // glyph height in px
  class?: string;
}
const { label, size = 14, class: cls = '' } = Astro.props;
---

<span class={`bfs-badge ${cls}`}>
  <svg width={size * (16 / 14)} height={size} viewBox="0 0 16 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="m13 0-1 5-4 9 8-9.5L13 0ZM3 0l1 5 4 9-8-9.5L3 0Z" fill="#1495CC"></path>
    <path d="m3 0 1 5 4 9 4-9 1-5H3Z" fill="#58B7DF"></path>
    <path d="M8 14 4 5l-4-.5L8 14ZM8 14l4-9 4-.5L8 14Z" fill="#035F86"></path>
    <path d="M8 5.5 4 5l4 9 4-9-4 .5Z" fill="#1495CC"></path>
    <path d="m4 5 4-5 4 5-4.001.5L4 5Z" fill="#A9DEF4"></path>
    <path d="M4 5 3 0h5L4 5ZM12 5l1-5H8l4 5Z" fill="#58B7DF"></path>
    <path d="M4 5 3 0 0 4.5 4 5ZM12 5l1-5 3 4.5-4 .5Z" fill="#1495CC"></path>
  </svg>
  <span class="bfs-label">{label}</span>
</span>

<style>
  .bfs-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    white-space: nowrap;
  }
  .bfs-badge svg {
    flex: none;
  }
  .bfs-label {
    font-weight: 600;
  }
</style>
