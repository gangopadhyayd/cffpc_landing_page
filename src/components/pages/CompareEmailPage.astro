---
import ContentPage from './ContentPage.astro';
import ComparisonTable from '../ComparisonTable.astro';
import { t } from '../../i18n';
import { preventionComparison } from '../../data/proofBlocks';

interface Props {
  locale: string;
  slug?: string;
}
const { locale, slug = '' } = Astro.props;
const tt = (k: string) => t(locale, k);
const comp = preventionComparison(locale);
---

<ContentPage
  locale={locale}
  slug={slug}
  pageKey="compare-email"
  sectionCount={3}
  faqCount={2}
  related={['vs-recovery', 'cornerstone', 'how-it-works']}
>
  <section class="content-section">
    <h2>{tt('content.comparisonTitle')}</h2>
    <ComparisonTable columns={comp.columns} rows={comp.rows} caption={tt('content.comparisonTitle')} />
    <p class="ce-foot">{tt('home.compare.footnote')}</p>
  </section>
</ContentPage>

<style>
  .ce-foot {
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    font-style: italic;
  }
</style>
