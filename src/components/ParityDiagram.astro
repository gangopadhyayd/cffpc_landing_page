---
import Icon from './Icon.astro';

/** Original, license-clean schematic: one cart on the customer's account,
 *  reachable from any device. No third-party retailer UI. */
interface Props {
  accountLabel: string;
  cartLabel: string;
  phoneLabel: string;
  laptopLabel: string;
  caption?: string;
}
const { accountLabel, cartLabel, phoneLabel, laptopLabel, caption } = Astro.props;
---

<figure class="parity-diagram">
  <div class="pd-scene">
    <div class="pd-device">
      <span class="pd-screen"><Icon name="smartphone" size={26} /></span>
      <span class="pd-label">{phoneLabel}</span>
    </div>

    <div class="pd-connector" aria-hidden="true"><span class="pd-dot"></span></div>

    <div class="pd-account">
      <span class="pd-account-icon"><Icon name="badge-check" size={18} /></span>
      <span class="pd-account-label">{accountLabel}</span>
      <span class="pd-cart">
        <Icon name="store" size={18} />
        <span>{cartLabel}</span>
      </span>
    </div>

    <div class="pd-connector" aria-hidden="true"><span class="pd-dot pd-dot-2"></span></div>

    <div class="pd-device">
      <span class="pd-screen"><Icon name="laptop" size={26} /></span>
      <span class="pd-label">{laptopLabel}</span>
    </div>
  </div>
  {caption && <figcaption class="pd-caption">{caption}</figcaption>}
</figure>

<style>
  .parity-diagram {
    background: radial-gradient(120% 120% at 50% 0%, color-mix(in srgb, var(--color-accent-tint) 40%, var(--color-card)) 0%, var(--color-card) 72%);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-xl);
    padding: clamp(1.5rem, 4vw, 2.75rem);
    box-shadow: var(--shadow-card);
  }
  .pd-scene {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    justify-items: center;
    gap: 0.5rem;
  }
  .pd-device {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .pd-screen {
    width: 4rem;
    height: 4rem;
    border-radius: var(--radius-lg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-card);
    border: 1px solid var(--color-hairline-strong);
    color: var(--color-ink);
    box-shadow: var(--shadow-card);
  }
  .pd-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
  }
  .pd-connector {
    position: relative;
    width: 2px;
    height: 2.5rem;
    background: linear-gradient(var(--color-accent), color-mix(in srgb, var(--color-accent) 30%, transparent));
    border-radius: 2px;
  }
  .pd-dot {
    position: absolute;
    left: 50%;
    top: 0;
    width: 8px;
    height: 8px;
    margin-left: -4px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: pd-travel 2.4s var(--ease-out-soft) infinite;
  }
  .pd-dot-2 {
    animation-delay: 1.2s;
  }
  @keyframes pd-travel {
    0% { top: 0; opacity: 0; }
    15% { opacity: 1; }
    85% { opacity: 1; }
    100% { top: 100%; opacity: 0; }
  }
  .pd-account {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    background: var(--color-ink);
    color: var(--color-paper);
    padding: 1rem 1.4rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-raised);
    text-align: center;
  }
  .pd-account-icon {
    color: var(--color-accent);
  }
  .pd-account-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #c9c1b4;
  }
  .pd-cart {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
    font-size: 0.95rem;
    background: rgb(255 255 255 / 0.1);
    padding: 0.4rem 0.7rem;
    border-radius: var(--radius-md);
  }
  .pd-cart :global(svg) {
    color: var(--color-accent);
  }
  .pd-caption {
    margin-top: 1.25rem;
    text-align: center;
    font-size: 0.84rem;
    color: var(--color-ink-soft);
    max-width: 40rem;
    margin-inline: auto;
  }
  @media (min-width: 760px) {
    .pd-scene {
      grid-template-columns: auto 1fr auto 1fr auto;
    }
    .pd-connector {
      width: auto;
      height: 2px;
      flex: 1;
      align-self: center;
      min-width: 3rem;
      background: linear-gradient(90deg, color-mix(in srgb, var(--color-accent) 30%, transparent), var(--color-accent), color-mix(in srgb, var(--color-accent) 30%, transparent));
    }
    .pd-dot {
      top: 50%;
      left: 0;
      margin-top: -4px;
      margin-left: 0;
      animation-name: pd-travel-h;
    }
    @keyframes pd-travel-h {
      0% { left: 0; opacity: 0; }
      15% { opacity: 1; }
      85% { opacity: 1; }
      100% { left: 100%; opacity: 0; }
    }
  }
</style>
