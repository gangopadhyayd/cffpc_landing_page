---
import Icon from './Icon.astro';

interface Props {
  quote: string;
  author: string;
  meta?: string;
  cta?: string;
  href?: string;
  external?: boolean;
}
const { quote, author, meta, cta, href, external = true } = Astro.props;
---

<figure class="testimonial">
  <span class="t-quote-mark"><Icon name="quote" size={28} /></span>
  <blockquote class="t-quote">{quote}</blockquote>
  <figcaption class="t-cap">
    <span class="t-author">{author}</span>
    {meta && <span class="t-meta">{meta}</span>}
  </figcaption>
  {
    cta && href && (
      <a class="t-cta link-underline" href={href} target={external ? '_blank' : undefined} rel={external ? 'noopener' : undefined}>
        {cta}
      </a>
    )
  }
</figure>

<style>
  .testimonial {
    background: var(--color-card);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    padding: clamp(1.75rem, 4vw, 3rem);
    max-width: 50rem;
    position: relative;
  }
  .t-quote-mark {
    color: var(--color-accent);
    display: inline-flex;
    margin-bottom: 0.75rem;
  }
  .t-quote {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.6vw, 1.7rem);
    line-height: 1.4;
    font-weight: 420;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }
  .t-cap {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .t-author {
    font-weight: 700;
  }
  .t-meta {
    font-size: 0.86rem;
    color: var(--color-ink-faint);
  }
  .t-cta {
    display: inline-block;
    margin-top: 1.1rem;
    font-size: 0.9rem;
    font-weight: 600;
  }
</style>
