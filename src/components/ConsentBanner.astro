---
/**
 * Lightweight, localized cookie-consent banner. Renders ONLY when GA4 (the
 * consent-requiring technology) is configured — Plausible is cookieless and needs
 * no banner, so when GA4 is absent there are no non-essential cookies to consent to.
 * GEO-GATED (owner decision 2026-07-08): shown only to visitors in
 * consent-required regions (window.pcNeedsConsent, defined by Analytics.astro);
 * everyone else gets GA without a banner. Accept → loads GA4; Decline → GA4
 * never loads anywhere. Choice persists in localStorage.
 */
import { t } from '../i18n';
import { localizedPath } from '../i18n/routing';

interface Props {
  locale: string;
}
const { locale } = Astro.props;
const GA_ID = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID;
const privacyHref = localizedPath(locale, 'privacy');
---

{
  GA_ID && (
    <div class="consent" data-consent hidden role="dialog" aria-label="Cookie consent" aria-live="polite">
      <p class="consent-text">
        {t(locale, 'consent.text')} <a href={privacyHref} class="consent-link">{t(locale, 'consent.privacy')}</a>
      </p>
      <div class="consent-actions">
        <button type="button" class="btn btn-secondary btn-sm" data-consent-decline>{t(locale, 'consent.decline')}</button>
        <button type="button" class="btn btn-primary btn-sm" data-consent-accept>{t(locale, 'consent.accept')}</button>
      </div>
    </div>
  )
}

<style>
  .consent {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    max-width: 36rem;
    margin-inline: auto;
    background: var(--color-card);
    border: 1px solid var(--color-hairline-strong);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-raised);
    padding: 1rem 1.1rem;
    z-index: 80;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
    justify-content: space-between;
  }
  .consent-text {
    font-size: 0.84rem;
    color: var(--color-ink-soft);
    flex: 1;
    min-width: 14rem;
    line-height: 1.5;
  }
  .consent-link {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .consent-actions {
    display: flex;
    gap: 0.5rem;
  }
  .btn-sm {
    padding: 0.5rem 0.85rem;
    font-size: 0.85rem;
  }
</style>

<script>
  (function () {
    const KEY = 'pc-consent';
    const found = document.querySelector<HTMLElement>('[data-consent]');
    if (!found) return;
    const banner = found; // non-null const — visible to the closures below
    // Show only in consent-required regions (pcNeedsConsent from Analytics.astro;
    // if it's somehow absent, fail safe to showing the banner).
    const needsConsent = (window as any).pcNeedsConsent ? (window as any).pcNeedsConsent() : true;
    if (!localStorage.getItem(KEY) && needsConsent) banner.hidden = false;

    function decide(v: string) {
      localStorage.setItem(KEY, v);
      banner.hidden = true;
      if (v === 'granted' && (window as any).pcLoadGA) (window as any).pcLoadGA();
    }
    banner.querySelector('[data-consent-accept]')?.addEventListener('click', () => decide('granted'));
    banner.querySelector('[data-consent-decline]')?.addEventListener('click', () => decide('denied'));
  })();
</script>
