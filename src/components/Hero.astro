---
/**
 * Hero: leak-first copy on the left; on the right THE FORK — one signed-in
 * shopper switches phone → laptop, and the same cart meets two futures:
 * "Default Shopify" (dashed path that never arrives, empty cart) vs
 * "With Persistent Cart" (marigold path, same cart, synced).
 *
 * Design round 2 (2026-07-07): the diagram ships in selectable creative
 * variants — set `heroVariant` in src/config/site.ts:
 *  - 'fork'  cycle-2 baseline: bare fork, dot rides the kept path
 *  - 'plate' editorial patent-plate: FIG. 1 header, dot-grid paper, plate
 *            border, "signed-in shopper" annotation, bolder paths
 *  - 'live'  plate chrome + live sync choreography: a 4th item pops into the
 *            phone cart, rides the path, lands in the laptop cart while the
 *            subtotal counts up (loop; resting state is the complete story)
 *  - 'real'  product-real screens: thumbnails, qty steppers, checkout button
 * No JS required for meaning: the resting state IS the end state; motion is
 * additive and disabled under prefers-reduced-motion.
 */
import BfsBadge from './BfsBadge.astro';
import { DEMO_ITEMS, DEMO_LIVE_ITEM, cartSubtotal, formatMoney } from '../data/demoCart';
import { localizedPath } from '../i18n/routing';
import { t } from '../i18n';
import { proof, appStoreLink, heroVariant } from '../config/site';

interface Props {
  locale: string;
}
const { locale } = Astro.props;

const howItWorksHref = localizedPath(locale, 'how-it-works');
const variant = heroVariant;
const isPlate = variant === 'plate' || variant === 'live';
const isLive = variant === 'live';
const isReal = variant === 'real';

const items = isLive ? [...DEMO_ITEMS, DEMO_LIVE_ITEM] : DEMO_ITEMS;
const subtotal = formatMoney(cartSubtotal(items));
const preSubtotal = formatMoney(cartSubtotal(DEMO_ITEMS)); // live: loop start value
---

<section class="hero">
  <div class="container-page hero-grid">
    <div class="hero-copy">
      {/* Proof row tops the fold (owner 2026-07-07 + fold benchmark): official
          badge + the 4.9★ chip ABOVE the H1 — the Social Snowball / Order
          Editing placement — so the rating is never buried under the copy. */}
      <div class="hero-proofrow">
        <BfsBadge label={t(locale, 'home.trust.stat.bfs')} variant="official" size={34} class="hero-bfs" />
        <a href={appStoreLink('hero_rating')} target="_blank" rel="noopener" class="trust-rating">
          <img class="trust-rating-glyph" src="/badges/shopify-glyph.svg" alt="" width="16" height="18" loading="eager" decoding="async" />
          <strong>{proof.reviewRating}★</strong> {t(locale, 'hero.trust.rating')}
        </a>
      </div>
      <h1 class="hero-title">
        <span class="lead">{t(locale, 'hero.h1.lead')}</span>
        <span class="turn">{t(locale, 'hero.h1.turn')}</span>
      </h1>
      <p class="hero-sub">{t(locale, 'hero.sub')}</p>

      <div class="hero-ctas">
        <a
          class="btn btn-primary"
          href={appStoreLink('hero')}
          target="_blank"
          rel="noopener"
          data-event="install_click"
          data-source="hero">{t(locale, 'cta.install')}</a
        >
        <a class="btn btn-secondary" href={howItWorksHref}>
          {t(locale, 'cta.seeHowItWorks')}
        </a>
      </div>

      <ul class="hero-trust">
        <li class="trust-impact">
          {/* Stat lockup, not a text line — the value AND its 30-day window are
              the point (owner 2026-07-07: window must be prominent, above the fold). */}
          <span class="impact-value tabular">{proof.syncedCartRevenue}</span>
          <span class="impact-text">
            {t(locale, 'trust.impact.qualifier')} — <strong>{t(locale, 'trust.impact.window')}</strong>
          </span>
        </li>
      </ul>
    </div>

    <div class="hero-visual">
      <figure class={`fork fork--${variant}`} data-fork data-variant={variant}>
        {isPlate && (
          <div class="plate-head" aria-hidden="true">
            <span class="fig-no">FIG. 1</span>
            <span class="fig-rule"></span>
            <span class="fig-label">{t(locale, 'hero.fig.label')}</span>
          </div>
        )}

        {/* 1 — the phone where the cart is built */}
        <div class="fork-phone">
          <div class="device device-phone">
            <span class="cam" aria-hidden="true"></span>
            <div class="screen">
              <div class="mc-head">
                <span class="mc-title">{t(locale, 'demo.cart.title')}</span>
              </div>
              <ul class="mc-items">
                {items.map((item) => (
                  <li class="mc-item" data-live-item={isLive && item.id === DEMO_LIVE_ITEM.id ? 'phone' : undefined}>
                    {/* No price column on the phone — names truncate (cycle-2 lesson). */}
                    <span class={`swatch ${isReal ? 'swatch-thumb' : ''}`} style={`background:${item.swatch}`}></span>
                    <span class="mc-name">{t(locale, item.nameKey)}</span>
                  </li>
                ))}
              </ul>
              <div class="mc-foot">
                <span>{t(locale, 'demo.cart.subtotal')}</span>
                <span class="tabular mc-subtotal" data-live-subtotal={isLive ? 'phone' : undefined}>{subtotal}</span>
              </div>
            </div>
            <span class="homebar" aria-hidden="true"></span>
          </div>
          <span class="device-tag">{t(locale, 'demo.device.phone')}</span>
          {isPlate && (
            <span class="annot annot-signedin" aria-hidden="true">{t(locale, 'hero.annot.signedIn')}</span>
          )}
        </div>

        {/* 2 — the switch: two paths out of one phone */}
        <svg class="fork-paths" viewBox="0 0 560 104" aria-hidden="true" fill="none">
          {isPlate && <circle class="origin-ring" cx="280" cy="7" r="4" />}
          <path class="path-lost" d="M280 6 C 280 56, 140 40, 140 68" />
          <g class="lost-x">
            <line x1="133" y1="76" x2="147" y2="90" />
            <line x1="147" y1="76" x2="133" y2="90" />
          </g>
          <path class="path-kept" data-kept d="M280 6 C 280 56, 420 36, 420 96" />
          <path class="kept-arrow" d="M413 88 L420 98 L427 88" />
          <circle class="kept-dot" data-dot r="5" cx="280" cy="6" />
        </svg>

        {/* 3 — the two futures, side by side */}
        <div class="fork-outcomes">
          <div class="outcome outcome-lost">
            <span class="chip chip-lost">{t(locale, 'home.problem.without.label')}</span>
            <div class="device device-laptop">
              <div class="screen screen-empty">
                <svg class="empty-cart" viewBox="0 0 24 24" aria-hidden="true" fill="none">
                  <path
                    d="M7 8h13l-1.5 7a1.5 1.5 0 0 1-1.47 1.2H10.3a1.5 1.5 0 0 1-1.47-1.18L6 4.9H3.6"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-dasharray="2.5 2.5"
                    stroke-linecap="round"
                  />
                  <circle cx="10.5" cy="19.4" r="1.3" fill="currentColor" opacity="0.55" />
                  <circle cx="16.6" cy="19.4" r="1.3" fill="currentColor" opacity="0.55" />
                </svg>
                <p class="empty-title">{t(locale, 'demo.cart.empty')}</p>
                <p class="empty-hint">{t(locale, 'demo.cart.emptyHint')}</p>
              </div>
              <span class="laptop-base" aria-hidden="true"></span>
            </div>
            <span class="device-tag">{t(locale, 'demo.device.laptop')}</span>
          </div>

          <div class="outcome outcome-kept">
            <span class="chip chip-kept">{t(locale, 'home.problem.with.label')}</span>
            <div class="device device-laptop">
              <div class="screen">
                <div class="mc-head">
                  <span class="mc-title">{t(locale, 'demo.cart.title')}</span>
                  <span class="sync-badge" data-sync-badge>
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    {t(locale, 'demo.cart.synced')}
                  </span>
                </div>
                <ul class="mc-items">
                  {items.map((item) => (
                    <li class="mc-item" data-live-item={isLive && item.id === DEMO_LIVE_ITEM.id ? 'laptop' : undefined}>
                      <span class={`swatch ${isReal ? 'swatch-thumb' : ''}`} style={`background:${item.swatch}`}></span>
                      <span class="mc-name">
                        {t(locale, item.nameKey)}
                        {isReal && <span class="mc-stepper" aria-hidden="true">−&ensp;1&ensp;+</span>}
                      </span>
                      <span class="mc-price tabular">{formatMoney(item.price)}</span>
                    </li>
                  ))}
                </ul>
                <div class="mc-foot">
                  <span>{t(locale, 'demo.cart.subtotal')}</span>
                  <span class="tabular mc-subtotal" data-live-subtotal={isLive ? 'laptop' : undefined}>{subtotal}</span>
                </div>
                {isReal && <span class="mc-checkout" aria-hidden="true">{t(locale, 'demo.cart.checkout')}</span>}
              </div>
              <span class="laptop-base" aria-hidden="true"></span>
            </div>
            <span class="device-tag">{t(locale, 'demo.device.laptop')}</span>
          </div>
        </div>

        <figcaption class="demo-caption">{t(locale, 'hero.demo.caption')}</figcaption>
      </figure>
    </div>
  </div>
</section>

<style define:vars={{ preSubtotal: `"${preSubtotal}"` }}>
  .hero {
    padding-block: clamp(2rem, 4.5vw, 3.75rem) clamp(2.5rem, 5vw, 4.5rem);
    position: relative;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
    /* start, not center: centering the shorter copy column against the tall
       plate left a dead band above the H1 on wide screens (owner 2026-07-07). */
    align-items: start;
  }
  .hero-copy {
    max-width: 40rem;
  }
  .hero-proofrow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem 1.15rem;
    margin-bottom: 1.35rem;
  }
  .hero-proofrow .trust-rating {
    font-size: 0.92rem;
    color: var(--color-ink-soft);
  }
  .hero-proofrow .trust-rating strong {
    font-size: 1.08rem;
  }
  .hero-title {
    font-size: clamp(1.9rem, 3.4vw, 2.7rem);
    margin: 0 0 1.15rem;
  }
  .hero-title .lead {
    display: block;
    color: var(--color-ink);
  }
  .hero-title .turn {
    display: block;
    color: var(--color-accent-ink);
  }
  .hero-sub {
    font-size: clamp(1rem, 1.8vw, 1.12rem);
    color: var(--color-ink-soft);
    line-height: 1.6;
    max-width: 36rem;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.75rem 0 1.25rem;
  }
  /* Stacked on purpose: with the Shopify glyph chip + "Shopify App Store"
     the two signals no longer share a line at desktop width, and a wrapped
     dot separator dangles — two clean rows read better. */
  .hero-trust {
    list-style: none;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.85rem;
    color: var(--color-ink-soft);
  }
  .hero-trust li {
    display: flex;
    align-items: center;
  }
  .trust-rating {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
  }
  .trust-rating-glyph {
    height: 18px;
    width: auto;
    flex: none;
  }
  .trust-rating strong {
    color: var(--color-accent-ink);
  }
  .trust-impact {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.2rem 0.55rem;
    color: var(--color-ink-soft);
  }
  .impact-value {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.4vw, 1.9rem);
    font-weight: 620;
    line-height: 1;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }
  .impact-text {
    font-size: 0.9rem;
  }
  .impact-text strong {
    color: var(--color-ink);
    font-weight: 700;
  }

  /* ---------- THE FORK ---------- */
  .fork {
    max-width: 32rem;
    margin-inline: auto;
  }

  /* --- plate chrome ('plate' + 'live'): the diagram becomes an editorial
         patent plate — bordered, dot-grid paper, mono figure header. --- */
  .fork--plate,
  .fork--live {
    max-width: 34rem;
    border: 1px solid var(--color-hairline-strong);
    border-radius: var(--radius-lg);
    background-color: var(--color-card-soft);
    background-image: radial-gradient(circle, rgb(28 24 21 / 0.055) 1px, transparent 1px);
    background-size: 18px 18px;
    padding: 1.1rem 1.25rem 1.2rem;
    box-shadow: var(--shadow-card);
  }
  .plate-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .fig-no {
    color: var(--color-accent-ink);
    font-weight: 500;
    flex: none;
  }
  .fig-rule {
    flex: 1;
    height: 1px;
    background: var(--color-hairline-strong);
  }
  .fig-label {
    color: var(--color-ink-faint);
    flex: none;
  }
  /* annotation with a leader line — encodes the honest scope: signed-in */
  .fork-phone {
    position: relative;
  }
  .annot {
    display: none;
    position: absolute;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
    max-width: 6.5rem;
    line-height: 1.5;
  }
  .annot-signedin {
    top: 16%;
    left: calc(50% + 5.6rem + 2.6rem);
    right: auto;
  }
  .annot-signedin::before {
    content: '';
    position: absolute;
    top: 0.45rem;
    left: -2.35rem;
    width: 2rem;
    height: 1px;
    background: var(--color-hairline-strong);
  }
  .annot-signedin::after {
    content: '';
    position: absolute;
    top: calc(0.45rem - 1.5px);
    left: -2.35rem;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-ink-faint);
  }
  @media (min-width: 1120px) {
    .fork--plate .annot,
    .fork--live .annot {
      display: block;
    }
  }
  .fork--plate .demo-caption,
  .fork--live .demo-caption {
    border-top: 1px solid var(--color-hairline);
    padding-top: 0.9rem;
    margin-top: 1.2rem;
  }
  .origin-ring {
    fill: var(--color-card-soft);
    stroke: color-mix(in srgb, var(--color-ink) 55%, transparent);
    stroke-width: 1.6;
  }
  .fork--plate .path-kept,
  .fork--plate .kept-arrow,
  .fork--live .path-kept,
  .fork--live .kept-arrow {
    stroke-width: 3;
  }

  /* device line-drawings — unmistakably a phone and laptops */
  .device {
    position: relative;
    background: var(--color-card);
    border: 3px solid color-mix(in srgb, var(--color-ink) 85%, transparent);
    box-shadow: var(--shadow-card);
  }
  .device-phone {
    width: min(11.2rem, 62%);
    aspect-ratio: 10 / 15.5;
    margin-inline: auto;
    border-radius: 26px;
    padding: 2rem 0.6rem 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  /* dynamic-island pill */
  .device-phone .cam {
    position: absolute;
    top: 9px;
    left: 50%;
    transform: translateX(-50%);
    width: 52px;
    height: 13px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-ink) 85%, transparent);
  }
  /* side button */
  .device-phone::after {
    content: '';
    position: absolute;
    top: 26%;
    right: -7px;
    width: 4px;
    height: 44px;
    border-radius: 3px;
    background: color-mix(in srgb, var(--color-ink) 85%, transparent);
  }
  .device-phone .homebar {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 46px;
    height: 4px;
    border-radius: 3px;
    background: color-mix(in srgb, var(--color-ink) 28%, transparent);
  }
  /* live: the phone needs a touch more vertical room for the 4th line */
  .fork--live .device-phone {
    aspect-ratio: 10 / 16.4;
  }
  .device-laptop {
    border-radius: 14px 14px 2px 2px;
    padding: 1.15rem 0.75rem 0.8rem;
  }
  /* webcam dot in the screen bezel */
  .device-laptop::before {
    content: '';
    position: absolute;
    top: 7px;
    left: 50%;
    transform: translateX(-50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-ink) 45%, transparent);
  }
  .device-laptop .screen {
    min-height: 9.4rem;
  }
  .fork--live .device-laptop .screen {
    min-height: 10.1rem;
  }
  .fork--real .device-laptop .screen {
    min-height: 10.6rem;
  }
  /* the deck: trapezoid base with a thumb scoop */
  .laptop-base {
    position: absolute;
    left: -4%;
    bottom: -11px;
    width: 108%;
    height: 9px;
    clip-path: polygon(2.5% 0, 97.5% 0, 100% 100%, 0 100%);
    border-radius: 0 0 6px 6px;
    background:
      linear-gradient(
        90deg,
        transparent 45.5%,
        color-mix(in srgb, var(--color-paper) 38%, transparent) 45.5% 54.5%,
        transparent 54.5%
      ),
      color-mix(in srgb, var(--color-ink) 85%, transparent);
  }
  .device-tag {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    justify-content: center;
    margin-top: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
  }
  .device-tag::before,
  .device-tag::after {
    content: '';
    width: 1.1rem;
    height: 1px;
    background: var(--color-hairline-strong);
  }

  /* mini cart UI inside screens */
  .screen {
    font-size: 0.78rem;
  }
  .device-phone .screen {
    padding-top: 0.35rem;
  }
  .mc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }
  .mc-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 540;
    color: var(--color-ink);
  }
  .mc-items {
    list-style: none;
    display: grid;
    gap: 0.42rem;
  }
  .mc-item {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    min-width: 0;
  }
  .swatch {
    width: 22px;
    height: 22px;
    border-radius: 5px;
    flex: none;
  }
  /* 'real': swatches become product thumbnails — a soft object silhouette */
  .swatch-thumb {
    width: 23px;
    height: 23px;
    border-radius: 6px;
    position: relative;
    overflow: hidden;
  }
  .swatch-thumb::after {
    content: '';
    position: absolute;
    right: -6px;
    bottom: -9px;
    width: 22px;
    height: 18px;
    border-radius: 60% 40% 55% 45%;
    background: rgb(255 255 255 / 0.42);
  }
  .mc-name {
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }
  .fork--real .mc-name {
    display: flex;
    flex-direction: column;
    line-height: 1.35;
  }
  .mc-stepper {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--color-ink-faint);
    border: 1px solid var(--color-hairline);
    border-radius: 999px;
    padding: 0.05rem 0.4rem;
    align-self: flex-start;
    white-space: nowrap;
  }
  .mc-price {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-ink-soft);
    flex: none;
  }
  .mc-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--color-hairline);
    margin-top: 0.55rem;
    padding-top: 0.45rem;
    font-size: 0.74rem;
    color: var(--color-ink-soft);
  }
  .mc-subtotal {
    font-weight: 700;
    font-size: 0.86rem;
    color: var(--color-ink);
  }
  .mc-checkout {
    display: block;
    margin-top: 0.55rem;
    padding: 0.42rem 0.6rem;
    border-radius: var(--radius-sm);
    background: var(--color-ink);
    color: var(--color-paper);
    font-weight: 600;
    font-size: 0.7rem;
    text-align: center;
    letter-spacing: 0.01em;
  }
  .sync-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: var(--color-evergreen-tint);
    color: var(--color-evergreen);
    white-space: nowrap;
  }

  /* the empty outcome — centered inside the same screen height as the synced one */
  .screen-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.3rem;
    color: var(--color-ink-faint);
  }
  .empty-cart {
    width: 30px;
    height: 30px;
  }
  .empty-title {
    font-weight: 600;
    color: var(--color-ink-soft);
    font-size: 0.82rem;
  }
  .empty-hint {
    font-size: 0.7rem;
    font-style: italic;
  }

  /* connector paths */
  .fork-paths {
    display: block;
    width: 100%;
    height: auto;
    margin-block: 0.15rem;
  }
  .path-lost {
    stroke: color-mix(in srgb, var(--color-ink) 45%, transparent);
    stroke-width: 2;
    stroke-dasharray: 5 6;
    stroke-linecap: round;
  }
  .lost-x line {
    stroke: color-mix(in srgb, var(--color-ink) 55%, transparent);
    stroke-width: 2.4;
    stroke-linecap: round;
  }
  .path-kept,
  .kept-arrow {
    stroke: var(--color-accent);
    stroke-width: 2.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .kept-dot {
    fill: var(--color-accent);
    opacity: 0;
  }

  /* outcome columns */
  .fork-outcomes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(0.9rem, 3vw, 1.6rem);
    align-items: start;
  }
  .outcome {
    display: flex;
    flex-direction: column;
  }
  .chip {
    align-self: center;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    padding: 0.28rem 0.6rem;
    border-radius: 999px;
    margin-bottom: 0.75rem;
    white-space: nowrap;
  }
  .chip-lost {
    color: var(--color-ink-soft);
    border: 1px solid var(--color-hairline-strong);
    background: var(--color-card-soft);
  }
  .chip-kept {
    color: var(--color-accent-ink);
    background: var(--color-accent-tint);
    border: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
  }
  .outcome .device {
    width: 100%;
  }
  .outcome .device-tag {
    margin-top: 1.15rem;
  }

  .demo-caption {
    margin-top: 1.4rem;
    text-align: center;
    font-size: 0.84rem;
    color: var(--color-ink-soft);
    max-width: 30rem;
    margin-inline: auto;
  }

  /* ---------- motion ----------
     The diagram is COMPLETE at rest — no entrance animation, so it is legible
     at every instant and identical under prefers-reduced-motion / no-JS.
     'fork'/'plate'/'real': one gesture — the cart-dot rides the marigold path.
     'live': the sync story loops — a 4th line item pops into the phone cart,
     the dot carries it across, the laptop cart receives it and the subtotal
     counts up. The JS only ever winds the carts BACK temporarily; markup
     always encodes the finished state. */
  @media (prefers-reduced-motion: no-preference) {
    .fork[data-anim] .sync-badge {
      animation: fork-pop 0.4s var(--ease-out-soft) 1.5s both;
    }
    /* The incoming row fades in PLACE — its slot stays reserved so the
       subtotal line and everything below never reflow (owner feedback
       2026-07-07: the collapse/expand read as "the animation moves the
       text around"). */
    .fork--live .mc-item[data-live-item] {
      transition: opacity 0.32s var(--ease-out-soft), transform 0.32s var(--ease-out-soft);
    }
    .fork--live[data-state='pre'] .mc-item[data-live-item],
    .fork--live[data-state='sending'] .mc-item[data-live-item='laptop'] {
      opacity: 0;
      transform: translateY(5px);
    }
    .fork--live [data-sync-badge] {
      transition: transform 0.3s var(--ease-out-soft);
    }
    .fork--live[data-pulse] [data-sync-badge] {
      animation: fork-pop 0.45s var(--ease-out-soft) both;
    }
  }
  @keyframes fork-pop {
    from {
      opacity: 0.35;
      transform: scale(0.7);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Small screens: the fork stacks — phone, then each future in reading order.
     The connector paths assume side-by-side geometry, so they step aside and
     the labeled chips carry the branching. */
  @media (max-width: 540px) {
    .fork-paths {
      display: none;
    }
    .fork-outcomes {
      grid-template-columns: 1fr;
      gap: 1.1rem;
      margin-top: 1.1rem;
    }
    .device-phone {
      width: min(12rem, 78%);
    }
    .fork--plate,
    .fork--live {
      padding: 0.9rem 0.9rem 1rem;
    }
  }

  @media (min-width: 980px) {
    .hero-grid {
      grid-template-columns: 1fr 1.05fr;
    }
  }
</style>

<script>
  // Motion director. Reads the variant off the figure; everything here is
  // additive — without JS (or with reduced motion) the resting markup already
  // shows the finished story.
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const fork = document.querySelector<HTMLElement>('[data-fork]');
  const kept = fork?.querySelector<SVGPathElement>('[data-kept]');
  const dot = fork?.querySelector<SVGCircleElement>('[data-dot]');

  if (fork && kept && dot && !prefersReduced) {
    const isLive = fork.dataset.variant === 'live';
    const len = kept.getTotalLength();

    const travel = (dur = 1100) =>
      new Promise<void>((resolve) => {
        const t0 = performance.now();
        dot.style.opacity = '1';
        const step = (now: number) => {
          const p = Math.min(1, (now - t0) / dur);
          const ease = p < 0.5 ? 2 * p * p : 1 - Math.pow(-2 * p + 2, 2) / 2;
          const pt = kept.getPointAtLength(ease * len);
          dot.setAttribute('cx', String(pt.x));
          dot.setAttribute('cy', String(pt.y));
          if (p < 1) requestAnimationFrame(step);
          else {
            setTimeout(() => {
              dot.style.opacity = '0';
            }, 250);
            resolve();
          }
        };
        requestAnimationFrame(step);
      });

    const countUp = (el: HTMLElement, from: number, to: number, dur = 480) => {
      const t0 = performance.now();
      const step = (now: number) => {
        const p = Math.min(1, (now - t0) / dur);
        el.textContent = '$' + (from + (to - from) * p).toFixed(2);
        if (p < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };

    const wait = (ms: number) => new Promise((r) => setTimeout(r, ms));

    // 'live': one full sync beat — wind back to 3 items, add on the phone,
    // carry it across, land it on the laptop. Ends in the resting state.
    const phoneSub = fork.querySelector<HTMLElement>('[data-live-subtotal="phone"]');
    const laptopSub = fork.querySelector<HTMLElement>('[data-live-subtotal="laptop"]');
    const restSub = phoneSub ? parseFloat((phoneSub.textContent || '').replace(/[^0-9.]/g, '')) : 0;
    const preSub = restSub - 18; // DEMO_LIVE_ITEM.price

    let playing = false;
    const liveBeat = async () => {
      if (playing || !phoneSub || !laptopSub) return;
      playing = true;
      fork.removeAttribute('data-pulse');
      fork.dataset.state = 'pre'; // both carts wind back to 3 items
      phoneSub.textContent = '$' + preSub.toFixed(2);
      laptopSub.textContent = '$' + preSub.toFixed(2);
      await wait(900);
      fork.dataset.state = 'sending'; // the 4th item lands in the phone
      countUp(phoneSub, preSub, restSub, 380);
      await wait(520);
      await travel(1100);
      delete fork.dataset.state; // …and arrives on the laptop
      countUp(laptopSub, preSub, restSub, 460);
      fork.setAttribute('data-pulse', '');
      playing = false;
    };

    const beat = () => {
      if (isLive) liveBeat();
      else travel();
    };

    let replay: ReturnType<typeof setInterval> | undefined;
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting && !replay) {
            if (!fork.dataset.anim) {
              fork.dataset.anim = '1';
              setTimeout(beat, 600);
            }
            replay = setInterval(() => {
              if (!document.hidden) beat();
            }, isLive ? 8000 : 6500);
          } else if (!e.isIntersecting && replay) {
            clearInterval(replay);
            replay = undefined;
          }
        }
      },
      { threshold: 0.35 }
    );
    io.observe(fork);
  }
</script>
