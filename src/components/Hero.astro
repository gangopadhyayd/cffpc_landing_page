---
/**
 * Hero: leak-first copy on the left; on the right THE FORK — one signed-in
 * shopper switches phone → laptop, and the same cart meets two futures:
 * "Default Shopify" (dashed path that never arrives, empty cart) vs
 * "With Persistent Cart" (marigold path, same cart, synced). Device frames are
 * hand-rolled line drawings (patent-diagram character, mono figure labels).
 * No JS required for meaning: the resting state IS the end state; motion is
 * additive and disabled under prefers-reduced-motion.
 */
import { DEMO_ITEMS, cartSubtotal, formatMoney } from '../data/demoCart';
import { localizedPath } from '../i18n/routing';
import { t } from '../i18n';
import { site, proof } from '../config/site';

interface Props {
  locale: string;
}
const { locale } = Astro.props;

const howItWorksHref = localizedPath(locale, 'how-it-works');
const items = DEMO_ITEMS;
const subtotal = formatMoney(cartSubtotal(items));
---

<section class="hero">
  <div class="container-page hero-grid">
    <div class="hero-copy">
      <h1 class="hero-title">
        <span class="lead">{t(locale, 'hero.h1.lead')}</span>
        <span class="turn">{t(locale, 'hero.h1.turn')}</span>
      </h1>
      <p class="hero-sub">{t(locale, 'hero.sub')}</p>

      <div class="hero-ctas">
        <a
          class="btn btn-primary"
          href={site.appStoreUrl}
          target="_blank"
          rel="noopener"
          data-event="install_click"
          data-source="hero">{t(locale, 'cta.install')}</a
        >
        <a class="btn btn-secondary" href={howItWorksHref}>
          {t(locale, 'cta.seeHowItWorks')}
        </a>
      </div>

      <ul class="hero-trust">
        <li>
          <a href={site.appStoreUrl} target="_blank" rel="noopener" class="trust-rating">
            <strong>{proof.reviewRating}★</strong> {t(locale, 'hero.trust.rating')}
          </a>
        </li>
        <li><span class="trust-bfs">{t(locale, 'hero.trust.bfs')}</span></li>
        <li>{t(locale, 'hero.trust.since')}</li>
      </ul>
    </div>

    <div class="hero-visual">
      <figure class="fork" data-fork>
        {/* 1 — the phone where the cart is built */}
        <div class="fork-phone">
          <div class="device device-phone">
            <span class="cam" aria-hidden="true"></span>
            <div class="screen">
              <div class="mc-head">
                <span class="mc-title">{t(locale, 'demo.cart.title')}</span>
              </div>
              <ul class="mc-items">
                {items.map((item) => (
                  <li class="mc-item">
                    <span class="swatch" style={`background:${item.swatch}`}></span>
                    <span class="mc-name">{t(locale, item.nameKey)}</span>
                  </li>
                ))}
              </ul>
              <div class="mc-foot">
                <span>{t(locale, 'demo.cart.subtotal')}</span>
                <span class="tabular mc-subtotal">{subtotal}</span>
              </div>
            </div>
            <span class="homebar" aria-hidden="true"></span>
          </div>
          <span class="device-tag">{t(locale, 'demo.device.phone')}</span>
        </div>

        {/* 2 — the switch: two paths out of one phone */}
        <svg class="fork-paths" viewBox="0 0 560 92" aria-hidden="true" fill="none">
          <path class="path-lost" d="M280 4 C 280 48, 140 34, 140 58" />
          <g class="lost-x">
            <line x1="133" y1="64" x2="147" y2="78" />
            <line x1="147" y1="64" x2="133" y2="78" />
          </g>
          <path class="path-kept" data-kept d="M280 4 C 280 48, 420 30, 420 84" />
          <path class="kept-arrow" d="M413 76 L420 86 L427 76" />
          <circle class="kept-dot" data-dot r="5" cx="280" cy="4" />
        </svg>

        {/* 3 — the two futures, side by side */}
        <div class="fork-outcomes">
          <div class="outcome outcome-lost">
            <span class="chip chip-lost">{t(locale, 'home.problem.without.label')}</span>
            <div class="device device-laptop">
              <div class="screen screen-empty">
                <svg class="empty-cart" viewBox="0 0 24 24" aria-hidden="true" fill="none">
                  <path
                    d="M7 8h13l-1.5 7a1.5 1.5 0 0 1-1.47 1.2H10.3a1.5 1.5 0 0 1-1.47-1.18L6 4.9H3.6"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-dasharray="2.5 2.5"
                    stroke-linecap="round"
                  />
                  <circle cx="10.5" cy="19.4" r="1.3" fill="currentColor" opacity="0.55" />
                  <circle cx="16.6" cy="19.4" r="1.3" fill="currentColor" opacity="0.55" />
                </svg>
                <p class="empty-title">{t(locale, 'demo.cart.empty')}</p>
                <p class="empty-hint">{t(locale, 'demo.cart.emptyHint')}</p>
              </div>
              <span class="laptop-base" aria-hidden="true"></span>
            </div>
            <span class="device-tag">{t(locale, 'demo.device.laptop')}</span>
          </div>

          <div class="outcome outcome-kept">
            <span class="chip chip-kept">{t(locale, 'home.problem.with.label')}</span>
            <div class="device device-laptop">
              <div class="screen">
                <div class="mc-head">
                  <span class="mc-title">{t(locale, 'demo.cart.title')}</span>
                  <span class="sync-badge">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    {t(locale, 'demo.cart.synced')}
                  </span>
                </div>
                <ul class="mc-items">
                  {items.map((item) => (
                    <li class="mc-item">
                      <span class="swatch" style={`background:${item.swatch}`}></span>
                      <span class="mc-name">{t(locale, item.nameKey)}</span>
                      <span class="mc-price tabular">{formatMoney(item.price)}</span>
                    </li>
                  ))}
                </ul>
                <div class="mc-foot">
                  <span>{t(locale, 'demo.cart.subtotal')}</span>
                  <span class="tabular mc-subtotal">{subtotal}</span>
                </div>
              </div>
              <span class="laptop-base" aria-hidden="true"></span>
            </div>
            <span class="device-tag">{t(locale, 'demo.device.laptop')}</span>
          </div>
        </div>

        <figcaption class="demo-caption">{t(locale, 'hero.demo.caption')}</figcaption>
      </figure>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(2rem, 4.5vw, 3.75rem) clamp(2.5rem, 5vw, 4.5rem);
    position: relative;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
  }
  .hero-copy {
    max-width: 40rem;
  }
  .hero-title {
    font-size: clamp(1.9rem, 3.4vw, 2.7rem);
    margin: 0 0 1.15rem;
  }
  .hero-title .lead {
    display: block;
    color: var(--color-ink);
  }
  .hero-title .turn {
    display: block;
    color: var(--color-accent-ink);
  }
  .hero-sub {
    font-size: clamp(1rem, 1.8vw, 1.12rem);
    color: var(--color-ink-soft);
    line-height: 1.6;
    max-width: 36rem;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.75rem 0 1.25rem;
  }
  .hero-trust {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1.1rem;
    font-size: 0.85rem;
    color: var(--color-ink-soft);
  }
  .hero-trust li {
    display: flex;
    align-items: center;
  }
  .hero-trust li + li::before {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-hairline-strong);
    margin-right: 1.1rem;
    margin-left: -0.55rem;
  }
  .trust-rating strong {
    color: var(--color-accent-ink);
  }
  .trust-bfs {
    font-weight: 600;
  }

  /* ---------- THE FORK ---------- */
  .fork {
    max-width: 32rem;
    margin-inline: auto;
  }

  /* device line-drawings (patent-diagram character) */
  .device {
    position: relative;
    background: var(--color-card);
    border: 2px solid color-mix(in srgb, var(--color-ink) 82%, transparent);
    box-shadow: var(--shadow-card);
  }
  .device-phone {
    width: min(12rem, 66%);
    margin-inline: auto;
    border-radius: 18px;
    padding: 1rem 0.6rem 0.9rem;
  }
  .device-phone .cam {
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 34px;
    height: 5px;
    border-radius: 3px;
    background: color-mix(in srgb, var(--color-ink) 82%, transparent);
  }
  .device-phone .homebar {
    position: absolute;
    bottom: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 42px;
    height: 3px;
    border-radius: 2px;
    background: color-mix(in srgb, var(--color-ink) 30%, transparent);
  }
  .device-laptop {
    border-radius: 10px 10px 3px 3px;
    padding: 0.7rem 0.75rem 0.8rem;
  }
  .device-laptop .screen {
    min-height: 8.45rem;
  }
  .laptop-base {
    position: absolute;
    left: -5%;
    bottom: -9px;
    width: 110%;
    height: 7px;
    border-radius: 2px 2px 5px 5px;
    background: color-mix(in srgb, var(--color-ink) 82%, transparent);
  }
  .device-tag {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    justify-content: center;
    margin-top: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
  }
  .device-tag::before,
  .device-tag::after {
    content: '';
    width: 1.1rem;
    height: 1px;
    background: var(--color-hairline-strong);
  }

  /* mini cart UI inside screens */
  .screen {
    font-size: 0.78rem;
  }
  .device-phone .screen {
    padding-top: 0.35rem;
  }
  .mc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }
  .mc-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 540;
    color: var(--color-ink);
  }
  .mc-items {
    list-style: none;
    display: grid;
    gap: 0.42rem;
  }
  .mc-item {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    min-width: 0;
  }
  .swatch {
    width: 22px;
    height: 22px;
    border-radius: 5px;
    flex: none;
  }
  .mc-name {
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }
  .mc-price {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-ink-soft);
    flex: none;
  }
  .mc-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--color-hairline);
    margin-top: 0.55rem;
    padding-top: 0.45rem;
    font-size: 0.74rem;
    color: var(--color-ink-soft);
  }
  .mc-subtotal {
    font-weight: 700;
    font-size: 0.86rem;
    color: var(--color-ink);
  }
  .sync-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: var(--color-evergreen-tint);
    color: var(--color-evergreen);
    white-space: nowrap;
  }

  /* the empty outcome — centered inside the same screen height as the synced one */
  .screen-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.3rem;
    color: var(--color-ink-faint);
  }
  .empty-cart {
    width: 30px;
    height: 30px;
  }
  .empty-title {
    font-weight: 600;
    color: var(--color-ink-soft);
    font-size: 0.82rem;
  }
  .empty-hint {
    font-size: 0.7rem;
    font-style: italic;
  }

  /* connector paths */
  .fork-paths {
    display: block;
    width: 100%;
    height: auto;
    margin-block: 0.15rem;
  }
  .path-lost {
    stroke: color-mix(in srgb, var(--color-ink) 45%, transparent);
    stroke-width: 2;
    stroke-dasharray: 5 6;
    stroke-linecap: round;
  }
  .lost-x line {
    stroke: color-mix(in srgb, var(--color-ink) 55%, transparent);
    stroke-width: 2.4;
    stroke-linecap: round;
  }
  .path-kept,
  .kept-arrow {
    stroke: var(--color-accent);
    stroke-width: 2.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .kept-dot {
    fill: var(--color-accent);
    opacity: 0;
  }

  /* outcome columns */
  .fork-outcomes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(0.9rem, 3vw, 1.6rem);
    align-items: start;
  }
  .outcome {
    display: flex;
    flex-direction: column;
  }
  .chip {
    align-self: center;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    padding: 0.28rem 0.6rem;
    border-radius: 999px;
    margin-bottom: 0.75rem;
    white-space: nowrap;
  }
  .chip-lost {
    color: var(--color-ink-soft);
    border: 1px solid var(--color-hairline-strong);
    background: var(--color-card-soft);
  }
  .chip-kept {
    color: var(--color-accent-ink);
    background: var(--color-accent-tint);
    border: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
  }
  .outcome .device {
    width: 100%;
  }
  .outcome .device-tag {
    margin-top: 1.15rem;
  }

  .demo-caption {
    margin-top: 1.4rem;
    text-align: center;
    font-size: 0.84rem;
    color: var(--color-ink-soft);
    max-width: 30rem;
    margin-inline: auto;
  }

  /* ---------- motion (one gesture: the cart-dot rides the marigold path) ----------
     The diagram is COMPLETE at rest — no entrance animation, so it is legible at
     every instant and identical under prefers-reduced-motion / no-JS. */
  @media (prefers-reduced-motion: no-preference) {
    .fork[data-anim] .sync-badge {
      animation: fork-pop 0.4s var(--ease-out-soft) 1.5s both;
    }
  }
  @keyframes fork-pop {
    from {
      opacity: 0.35;
      transform: scale(0.7);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Small screens: the fork stacks — phone, then each future in reading order.
     The connector paths assume side-by-side geometry, so they step aside and
     the labeled chips carry the branching. */
  @media (max-width: 540px) {
    .fork-paths {
      display: none;
    }
    .fork-outcomes {
      grid-template-columns: 1fr;
      gap: 1.1rem;
      margin-top: 1.1rem;
    }
    .device-phone {
      width: min(12rem, 78%);
    }
  }

  @media (min-width: 980px) {
    .hero-grid {
      grid-template-columns: 1fr 1.05fr;
    }
  }
</style>

<script>
  // The fork's motion: draw the marigold path and send the cart-dot down it.
  // Purely additive — without JS (or with reduced motion) the resting markup
  // already shows the finished story.
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const fork = document.querySelector<HTMLElement>('[data-fork]');
  const kept = fork?.querySelector<SVGPathElement>('[data-kept]');
  const dot = fork?.querySelector<SVGCircleElement>('[data-dot]');

  if (fork && kept && dot && !prefersReduced) {
    const len = kept.getTotalLength();

    const travel = () => {
      const t0 = performance.now();
      const dur = 1100;
      dot.style.opacity = '1';
      const step = (now: number) => {
        const p = Math.min(1, (now - t0) / dur);
        const ease = p < 0.5 ? 2 * p * p : 1 - Math.pow(-2 * p + 2, 2) / 2;
        const pt = kept.getPointAtLength(ease * len);
        dot.setAttribute('cx', String(pt.x));
        dot.setAttribute('cy', String(pt.y));
        if (p < 1) requestAnimationFrame(step);
        else setTimeout(() => (dot.style.opacity = '0'), 300);
      };
      requestAnimationFrame(step);
    };

    let replay: ReturnType<typeof setInterval> | undefined;
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting && !replay) {
            if (!fork.dataset.anim) {
              fork.dataset.anim = '1';
              setTimeout(travel, 500);
            }
            replay = setInterval(() => {
              if (!document.hidden) travel();
            }, 6500);
          } else if (!e.isIntersecting && replay) {
            clearInterval(replay);
            replay = undefined;
          }
        }
      },
      { threshold: 0.35 }
    );
    io.observe(fork);
  }
</script>
