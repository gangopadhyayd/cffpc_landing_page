---
import CartCard from './CartCard.astro';
import { DEMO_ITEMS } from '../data/demoCart';
import { localizedPath } from '../i18n/routing';
import { t } from '../i18n';
import { site } from '../config/site';
import { proof } from '../config/site';

interface Props {
  locale: string;
}
const { locale } = Astro.props;

const howItWorksHref = localizedPath(locale, 'how-it-works');
const phoneItems = DEMO_ITEMS; // device where the 3rd item was added
const laptopItems = DEMO_ITEMS; // synced to match
---

<section class="hero">
  <div class="container-page hero-grid">
    <div class="hero-copy">
      <h1 class="hero-title">
        <span class="lead">{t(locale, 'hero.h1.lead')}</span>
        <span class="turn">{t(locale, 'hero.h1.turn')}</span>
      </h1>
      <p class="hero-sub">{t(locale, 'hero.sub')}</p>

      <div class="hero-ctas">
        <a
          class="btn btn-primary"
          href={site.appStoreUrl}
          target="_blank"
          rel="noopener"
          data-event="install_click"
          data-source="hero">{t(locale, 'cta.install')}</a
        >
        <a class="btn btn-secondary" href={howItWorksHref}>
          {t(locale, 'cta.seeHowItWorks')}
        </a>
      </div>

      <ul class="hero-trust">
        <li>
          <a href={site.appStoreUrl} target="_blank" rel="noopener" class="trust-rating">
            <strong>{proof.reviewRating}★</strong> {t(locale, 'hero.trust.rating')}
          </a>
        </li>
        <li><span class="trust-bfs">{t(locale, 'hero.trust.bfs')}</span></li>
        <li>{t(locale, 'hero.trust.since')}</li>
      </ul>
    </div>

    <div class="hero-visual">
      <div class="demo-scene" aria-hidden="false">
        <div class="demo-device demo-phone">
          <CartCard locale={locale} device="phone" items={phoneItems} synced={true} />
        </div>
        <div class="demo-link" aria-hidden="true">
          <span class="pulse"></span>
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none">
            <path d="M4 12h16M14 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <div class="demo-device demo-laptop">
          <CartCard locale={locale} device="laptop" items={laptopItems} synced={true} />
        </div>
      </div>
      <p class="demo-caption">{t(locale, 'hero.demo.caption')}</p>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(2rem, 4.5vw, 3.75rem) clamp(2.5rem, 5vw, 4.5rem);
    position: relative;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
  }
  .hero-copy {
    max-width: 40rem;
  }
  .hero-title {
    font-size: clamp(1.9rem, 3.4vw, 2.7rem);
    margin: 0 0 1.15rem;
  }
  .hero-title .lead {
    display: block;
    color: var(--color-ink);
  }
  .hero-title .turn {
    display: block;
    color: var(--color-accent-ink);
  }
  .hero-sub {
    font-size: clamp(1rem, 1.8vw, 1.12rem);
    color: var(--color-ink-soft);
    line-height: 1.6;
    max-width: 36rem;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.75rem 0 1.25rem;
  }
  .hero-trust {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1.1rem;
    font-size: 0.85rem;
    color: var(--color-ink-soft);
  }
  .hero-trust li {
    display: flex;
    align-items: center;
  }
  .hero-trust li + li::before {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-hairline-strong);
    margin-right: 1.1rem;
    margin-left: -0.55rem;
  }
  .trust-rating strong {
    color: var(--color-accent-ink);
  }
  .trust-bfs {
    font-weight: 600;
  }

  .hero-visual {
    position: relative;
  }
  .demo-scene {
    display: grid;
    gap: 1rem;
    align-items: center;
    grid-template-columns: 1fr;
    background: radial-gradient(120% 120% at 50% 0%, color-mix(in srgb, var(--color-accent-tint) 50%, var(--color-paper)) 0%, var(--color-paper) 70%);
    padding: clamp(1rem, 3vw, 1.75rem);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-xl);
  }
  .demo-phone {
    max-width: 19rem;
    margin-inline: auto;
  }
  .demo-laptop {
    max-width: 26rem;
    margin-inline: auto;
  }
  .demo-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    position: relative;
  }
  .demo-link .pulse {
    position: absolute;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.18;
    animation: pulse 2.4s var(--ease-out-soft) infinite;
  }
  @keyframes pulse {
    0% { transform: scale(0.6); opacity: 0.28; }
    70% { transform: scale(1.4); opacity: 0; }
    100% { opacity: 0; }
  }
  .demo-caption {
    margin-top: 1rem;
    text-align: center;
    font-size: 0.84rem;
    color: var(--color-ink-soft);
    max-width: 32rem;
    margin-inline: auto;
  }

  @media (min-width: 720px) {
    .demo-scene {
      grid-template-columns: 1fr auto 1.35fr;
    }
    .demo-link svg {
      transform: none;
    }
  }
  @media (min-width: 980px) {
    .hero-grid {
      grid-template-columns: 1fr 1.05fr;
    }
  }
</style>
